---
export const prerender = false;

import Layout from "../../layouts/Layout.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import { getProjectsFromPocketBase } from "../../lib/pocketbase.js";
import Navigation from "../../components/Navigation.astro";

const { slug } = Astro.params;

const categoryNames = {
    motion: "Видеографика",
    illustration: "Орнаменты",
    carre: "Орнаменты Carré",
    packaging: "Прикладное искусство",
};

const categoryTitle =
    categoryNames[slug] || slug.charAt(0).toUpperCase() + slug.slice(1);

const projectsData = await getProjectsFromPocketBase({
    category: slug,
    perPage: 20,
});

const projects = projectsData.items;
---

<Layout title={`${categoryTitle} | Портфолио`}>
    <Navigation />

    <section class="max-w-7xl mx-auto px-6 pt-16 pb-8">
        <a
            href="/"
            class="inline-flex items-center gap-2 text-zinc-500 hover:text-zinc-900 dark:hover:text-white mb-6"
        >
            ← На главную
        </a>

        <h1 class="text-5xl font-display tracking-tighter font-semibold mb-2">
            {categoryTitle}
        </h1>
        <p class="text-xl text-zinc-600 dark:text-zinc-400">
            Все проекты в этой категории
        </p>
    </section>

    <section class="max-w-7xl mx-auto px-6 pb-24">
        {
            projects.length > 0 ? (
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                    {projects.map((project) => {
                        return <ProjectCard project={project} />
                    })}
                </div>
            ) : (
                <div class="text-center py-24">
                    <p class="text-2xl text-zinc-400">
                        В этой категории пока нет работ
                    </p>
                </div>
            )
        }
    </section>
</Layout>

<script>
    console.log("!!");
    
</script>