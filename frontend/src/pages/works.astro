---
export const prerender = false;

import Layout from "../layouts/Layout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { getProjectsFromPocketBase } from "../lib/pocketbase.js";
import { categories } from "../const";
import Navigation from "../components/Navigation.astro";

const url = new URL(Astro.request.url);
const selectedCategory = url.searchParams.get("category") || "";

const projectsData = await getProjectsFromPocketBase({
    category: selectedCategory,
    perPage: 9,
    page: 1,
});

const projects = projectsData.items;
const totalPages = projectsData.totalPages;
---

<Layout title="Все работы | Портфолио">
    <Navigation />
    <section class="max-w-7xl mx-auto px-6 pt-16 pb-8">
        <h1 class="text-5xl font-display tracking-tighter font-semibold mb-3">
            Все работы
        </h1>
        <p class="text-zinc-600 dark:text-zinc-400">
            Портфолио графического дизайна
        </p>
    </section>

    <!-- Фильтры по категориям -->
    <section class="max-w-7xl mx-auto px-6 pb-8">
        <div class="flex flex-wrap gap-3">
            {
                categories.map((cat) => (
                    <a
                        href={`/works${cat.slug ? `?category=${cat.slug}` : ""}`}
                        class={`px-6 py-3 rounded-2xl text-sm font-medium transition-all ${
                            selectedCategory === cat.slug
                                ? "bg-violet-600 text-white shadow"
                                : "bg-zinc-100 dark:bg-zinc-900 hover:bg-zinc-200 dark:hover:bg-zinc-800"
                        }`}
                    >
                        {cat.label}
                    </a>
                ))
            }
        </div>
    </section>

    <!-- Сетка проектов -->
    <section class="max-w-7xl mx-auto px-6 pb-16">
        <div
            id="projects-grid"
            class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8"
        >
            {projects.map((project) => <ProjectCard project={project} />)}
        </div>

        <!-- Кнопка "Загрузить ещё" -->
        <div class="text-center mt-16" id="load-more-container">
            <button
                id="load-more"
                class="px-10 py-4 bg-black text-white dark:bg-white dark:text-black rounded-2xl font-medium hover:bg-violet-600 transition-all disabled:opacity-50"
                data-page="2"
                data-category={selectedCategory}
                {totalPages <= 1 && 'disabled'}
            >
                Загрузить ещё
            </button>
        </div>
    </section>

    <script>
        const loadMoreBtn = document.getElementById("load-more");
        const grid = document.getElementById("projects-grid");
        let currentPage = 2;
        let isLoading = false;

        async function loadMore() {
            if (isLoading) return;
            isLoading = true;
            loadMoreBtn.disabled = true;
            loadMoreBtn.textContent = "Загрузка...";

            const category = loadMoreBtn.dataset.category;

            try {
                const res = await fetch(
                    `/api/projects?page=${currentPage}&category=${encodeURIComponent(category)}`,
                );
                const data = await res.json();

                if (data.items?.length > 0) {
                    data.items.forEach((project) => {
                        const cardHTML = `
              <a href="/project/${project.slug}" class="project-card group block bg-white dark:bg-zinc-900 rounded-3xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300">
                <div class="aspect-[16/13] overflow-hidden">
                  <img src="http://127.0.0.1:8090/api/files/${project.collectionId}/${project.id}/${project.cover}" 
                       class="w-full h-full object-cover transition-transform group-hover:scale-105 duration-500" />
                </div>
                <div class="p-6">
                  <span class="inline-block px-3 py-1 text-xs font-medium bg-violet-100 dark:bg-violet-950 text-violet-600 dark:text-violet-400 rounded-full">
                    ${project.category}
                  </span>
                  <h3 class="text-2xl font-display font-semibold mt-4 mb-1">${project.title}</h3>
                  <p class="text-zinc-500 text-sm line-clamp-2">${project.shortDesc || project.description?.substring(0, 100) || ""}</p>
                </div>
              </a>
            `;
                        grid.insertAdjacentHTML("beforeend", cardHTML);
                    });

                    currentPage++;

                    if (currentPage > data.totalPages) {
                        loadMoreBtn.style.display = "none";
                    }
                } else {
                    loadMoreBtn.style.display = "none";
                }
            } catch (e) {
                console.error(e);
            } finally {
                isLoading = false;
                loadMoreBtn.disabled = false;
                loadMoreBtn.textContent = "Загрузить ещё";
            }
        }

        loadMoreBtn.addEventListener("click", loadMore);
    </script>
</Layout>
